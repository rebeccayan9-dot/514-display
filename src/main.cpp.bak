/*
 * ================================================================
 *  514 – Display Node  (Gauge Node)
 *  Board : Seeed Studio XIAO ESP32-C3
 * ================================================================
 *  Connects to the Vision Node over BLE as a central/client.
 *  Drives a 28BYJ-48 stepper pointer + WS2812B NeoPixel.
 *
 *  BLE "FOCUS" → stepper 45° right, LED red.
 *  3 min of FOCUS → stepper 180° (max), LED cycles red/yellow/blue/green.
 *  BLE "REST"  → stepper home, LED green.
 *  Button → stepper home, cancel alarm.
 * ================================================================
 */

#include <Arduino.h>
#include <AccelStepper.h>
#include <Adafruit_NeoPixel.h>
#include <BLEDevice.h>
#include <BLEUtils.h>
#include <BLEScan.h>
#include <BLEAdvertisedDevice.h>
#include <BLEClient.h>

// ── Pin definitions ──────────────────────────────────────────────────────────
//
//  28BYJ-48 coil winding order required by Stepper.h for smooth rotation:
//  Stepper(steps, IN1, IN3, IN2, IN4)  →  passes them in 1-3-2-4 sequence.
#define STEP_P1   D0   // ULN2003 IN1
#define STEP_P2   D2   // ULN2003 IN3  (listed 2nd → Stepper uses 1-3-2-4)
#define STEP_P3   D1   // ULN2003 IN2
#define STEP_P4   D3   // ULN2003 IN4

#define BTN_PIN   D6   // Active-LOW (INPUT_PULLUP), to GND
#define LED_PIN   D10  // WS2812B DIN
#define NPIX      1


// ── Stepper ──────────────────────────────────────────────────────────────────
#define STEPS_REV   4096    // 28BYJ-48 half-step with 64:1 gearbox
#define MOTOR_MAX_SPEED   500
#define MOTOR_ACCEL       200

// ▼ Tune these step counts to match your physical dial face ▼
#define POS_HOME    0
#define POS_REST    0          //   0° – idle / rest
#define POS_FOCUS   512        //  45° – person detected  (= STEPS_REV / 8)
#define POS_ALARM   2048       // 180° – been sitting 3 min (= STEPS_REV / 2)

// How long in FOCUS before alarm triggers
#define ALARM_DELAY_MS   (3UL * 60UL * 1000UL)   // 3 minutes
#define ALARM_COLOR_MS   500                       // cycle colour every 500 ms

// ── BLE ──────────────────────────────────────────────────────────────────────
// ▼ These MUST match exactly what your Vision Node advertises ▼
#define VISION_NAME   "514-VisionNode"
#define SVC_UUID      "4fafc201-1fb5-459e-8fcc-c5c9c331914b"
#define CHAR_UUID     "beb5483e-36e1-4688-b7f5-ea07361b26a8"

#define SIG_FOCUS     "FOCUS"
#define SIG_REST      "REST"
#define SCAN_DUR_S    5      // seconds per BLE scan window


// ── Alarm colour cycle: red → yellow → blue → green ─────────────────────────
static const uint8_t ALARM_COLORS[4][3] = {
    {200,   0,   0},
    {200, 150,   0},
    {  0,   0, 200},
    {  0, 200,   0},
};

// ── Objects & state ──────────────────────────────────────────────────────────
// HALF4WIRE mode: IN1, IN3, IN2, IN4 sequence for 28BYJ-48
AccelStepper      motor(AccelStepper::HALF4WIRE, D0, D2, D1, D3);
Adafruit_NeoPixel strip(NPIX, LED_PIN, NEO_GRB + NEO_KHZ800);

int curPos = 0;

enum GaugeState { STATE_REST, STATE_FOCUS, STATE_ALARM };
GaugeState    gaugeState    = STATE_REST;
unsigned long focusStartMs  = 0;
unsigned long lastAlarmMs   = 0;
int           alarmColorIdx = 0;

static bool                     bleFound      = false;
static bool                     bleConn       = false;
static bool                     bleScanning   = false;
static unsigned long            scanStartMs   = 0;
static BLEAdvertisedDevice*     pTarget  = nullptr;
static BLEClient*               pClient  = nullptr;
static BLERemoteCharacteristic* pChar    = nullptr;

// ── Forward declarations ──────────────────────────────────────────────────────
void doRest();
void doFocus();

bool connectBLE();
void startScan();

// ─────────────────────────────────────────────────────────────────────────────
//  Stepper helpers
// ─────────────────────────────────────────────────────────────────────────────

// Power off coils when stationary – prevents overheating.
void stepperOff() {
    motor.disableOutputs();
}

// Absolute move (blocking).
void moveTo(int target) {
    motor.enableOutputs();
    motor.moveTo(target);
    while (motor.distanceToGo() != 0) motor.run();
    curPos = target;
    stepperOff();
}

// ─────────────────────────────────────────────────────────────────────────────
//  NeoPixel helpers
// ─────────────────────────────────────────────────────────────────────────────
void setLED(uint8_t r, uint8_t g, uint8_t b) {
    strip.setPixelColor(0, strip.Color(r, g, b));
    strip.show();
}

void ledOff() {
    strip.clear();
    strip.show();
}

// ─────────────────────────────────────────────────────────────────────────────
//  Gauge actions
// ─────────────────────────────────────────────────────────────────────────────
void doFocus() {
    Serial.println("[GAUGE] FOCUS");
    if (gaugeState == STATE_REST) {
        // First FOCUS after rest – move to 45° and start timer
        focusStartMs = millis();
        moveTo(POS_FOCUS);
        setLED(200, 0, 0);    // Red
        gaugeState = STATE_FOCUS;
    }
    // Already FOCUS or ALARM – keep current position, timer keeps running
}

void doRest() {
    Serial.println("[GAUGE] REST");
    gaugeState = STATE_REST;
    moveTo(POS_REST);
    setLED(0, 200, 0);    // Green
}


// ─────────────────────────────────────────────────────────────────────────────
//  BLE – notification from Vision Node
// ─────────────────────────────────────────────────────────────────────────────
void notifyCB(BLERemoteCharacteristic*, uint8_t* data, size_t len, bool) {
    String val;
    val.reserve(len);
    for (size_t i = 0; i < len; i++) val += (char)data[i];
    Serial.print("[BLE] Notify: "); Serial.println(val);
    if      (val == SIG_FOCUS) doFocus();
    else if (val == SIG_REST)  doRest();
}

// ─────────────────────────────────────────────────────────────────────────────
//  BLE – client connection callbacks
// ─────────────────────────────────────────────────────────────────────────────
class ClientCB : public BLEClientCallbacks {
    void onConnect(BLEClient*) override {
        bleConn = true;
        Serial.println("[BLE] Connected to Vision Node");
        setLED(0, 0, 200);    // Blue – connected to camera
    }
    void onDisconnect(BLEClient*) override {
        bleConn   = false;
        bleFound  = false;
        Serial.println("[BLE] Disconnected");
        setLED(200, 200, 0);  // Yellow – link lost, will rescan
        startScan();
    }
};

// ─────────────────────────────────────────────────────────────────────────────
//  BLE – scan callbacks
// ─────────────────────────────────────────────────────────────────────────────
class ScanCB : public BLEAdvertisedDeviceCallbacks {
    void onResult(BLEAdvertisedDevice dev) override {
        Serial.printf("[BLE] Found: %s\n", dev.getName().c_str());
        if (dev.haveServiceUUID() &&
            dev.isAdvertisingService(BLEUUID(SVC_UUID))) {
            BLEDevice::getScan()->stop();
            pTarget     = new BLEAdvertisedDevice(dev);
            bleFound    = true;
            bleScanning = false;
        }
    }

};

// ─────────────────────────────────────────────────────────────────────────────
//  BLE – connect, discover service & characteristic, subscribe
// ─────────────────────────────────────────────────────────────────────────────
bool connectBLE() {
    Serial.printf("[BLE] Connecting to %s\n",
                  pTarget->getAddress().toString().c_str());

    pClient = BLEDevice::createClient();
    pClient->setClientCallbacks(new ClientCB());

    if (!pClient->connect(pTarget)) {
        Serial.println("[BLE] Connect failed");
        return false;
    }

    BLERemoteService* svc = pClient->getService(SVC_UUID);
    if (!svc) {
        Serial.println("[BLE] Service not found");
        pClient->disconnect();
        return false;
    }

    pChar = svc->getCharacteristic(CHAR_UUID);
    if (!pChar) {
        Serial.println("[BLE] Characteristic not found");
        pClient->disconnect();
        return false;
    }

    if (pChar->canNotify()) {
        pChar->registerForNotify(notifyCB);
        Serial.println("[BLE] Subscribed to notifications");
    }

    // Read current state immediately so the gauge is correct on first connect.
    if (pChar->canRead()) {
        std::string raw = pChar->readValue();
        String val(raw.c_str());
        Serial.print("[BLE] Initial value: "); Serial.println(val);
        if (val == SIG_FOCUS) doFocus();
        else                  doRest();
    }

    return true;
}

// ─────────────────────────────────────────────────────────────────────────────
//  BLE – (re)start scan helper
// ─────────────────────────────────────────────────────────────────────────────
void startScan() {
    Serial.println("[BLE] Scanning for Vision Node...");
    setLED(255, 255, 255);                            // White = starting up / searching
    bleScanning = true;
    scanStartMs = millis();
    BLEDevice::getScan()->start(SCAN_DUR_S, false);   // non-blocking
}

// ─────────────────────────────────────────────────────────────────────────────
//  setup()
// ─────────────────────────────────────────────────────────────────────────────
void setup() {
    Serial.begin(115200);
    delay(300);

    Serial.println("[BOOT] Start");
    curPos = 0;

    // NeoPixel
    strip.begin();
    strip.setBrightness(80);
    ledOff();

    // Button
    pinMode(BTN_PIN, INPUT_PULLUP);

    // Stepper
    motor.setMaxSpeed(MOTOR_MAX_SPEED);
    motor.setAcceleration(MOTOR_ACCEL);
    motor.setCurrentPosition(0);

    // Boot sweep: half rotation then back to home
    moveTo(STEPS_REV / 2);
    moveTo(0);

    // BLE – init as central (client)
    BLEDevice::init("514-GaugeNode");
    BLEScan* scan = BLEDevice::getScan();
    scan->setAdvertisedDeviceCallbacks(new ScanCB());
    scan->setActiveScan(true);
    scan->setInterval(100);
    scan->setWindow(99);

    startScan();
}

// ─────────────────────────────────────────────────────────────────────────────
//  loop()
// ─────────────────────────────────────────────────────────────────────────────
void loop() {

    // ── Button: manual home reset + cancel alarm ───────────────────────────
    if (digitalRead(BTN_PIN) == LOW) {
        delay(50);
        if (digitalRead(BTN_PIN) == LOW) {
            Serial.println("[BTN] Reset");
            gaugeState = STATE_REST;
            moveTo(POS_HOME);
            setLED(0, 200, 0);
            while (digitalRead(BTN_PIN) == LOW) delay(10);
        }
    }

    // ── Alarm trigger after 3 min of FOCUS ────────────────────────────────
    if (gaugeState == STATE_FOCUS &&
        millis() - focusStartMs >= ALARM_DELAY_MS) {
        Serial.println("[GAUGE] ALARM – get up!");
        gaugeState    = STATE_ALARM;
        lastAlarmMs   = millis();
        alarmColorIdx = 0;
        moveTo(POS_ALARM);
    }

    // ── Alarm LED colour cycling ───────────────────────────────────────────
    if (gaugeState == STATE_ALARM &&
        millis() - lastAlarmMs >= ALARM_COLOR_MS) {
        lastAlarmMs   = millis();
        alarmColorIdx = (alarmColorIdx + 1) % 4;
        setLED(ALARM_COLORS[alarmColorIdx][0],
               ALARM_COLORS[alarmColorIdx][1],
               ALARM_COLORS[alarmColorIdx][2]);
    }

    // ── BLE state machine ──────────────────────────────────────────────────
    if (bleFound && !bleConn) {
        // Vision Node was found during scan – attempt connection
        if (!connectBLE()) {
            // Failed – clean up and restart scan
            bleFound = false;
            delete pTarget;
            pTarget = nullptr;
            startScan();
        }
    } else if (!bleConn && !bleFound && bleScanning &&
               millis() - scanStartMs >= (SCAN_DUR_S * 1000UL)) {
        bleScanning = false;
    } else if (!bleConn && !bleFound && !bleScanning) {
        // Scan ended without finding Vision Node – retry
        startScan();
    }

    delay(100);
}
